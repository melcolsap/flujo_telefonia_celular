<mvc:View controllerName="co.mitsubishi.flujotelefoniacelular.controller.Detail"
    xmlns:form="sap.ui.layout.form"
    xmlns:unified="sap.ui.unified"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Page id="detailPage" title="{i18n>detailViewTitle}{ui>/IdSolicitud}">
        <content>
            <VBox id="mainDetailPageVbox" class="sapUiSmallMarginBegin sapUiSmallMarginEnd">

                <Panel id="panelRequestForm" headerText="{i18n>titleRequestForm}" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
                    <form:SimpleForm id="requestSimpleForm" editable="{viewState>/Editable}" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="2" columnsM="2">
                        <Label id="lblCreadorSolicitud" text="{i18n>lblCreadorSolicitud}" visible="false"/>
                        <Input id="inpCreadorSolicitud" value="{ui>/CreadorSolicitud}" editable="false" visible="false" valueLiveUpdate="true"/>

                        <Label id="lblTipoSolicitud" text="{i18n>lblTipoSolicitud}" visible="{viewState>/fields/TipoSolicitud}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/TipoSolicitud} }"/>
                        <Select id="selTipoSolicitud" selectedKey="{ui>/TipoSolicitud}" editable="{viewState>/Editable}" change="onTipoSolicitudChange" visible="{viewState>/fields/TipoSolicitud}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/TipoSolicitud} &amp;&amp; !${ui>/TipoSolicitud} ? 'Error' : 'None' }">
                            <items>
                                <core:Item id="itemTipoSolicitud1" key="1" text="{i18n>optTipoSolicitud1}"/>
                                <core:Item id="itemTipoSolicitud2" key="2" text="{i18n>optTipoSolicitud2}"/>
                                <core:Item id="itemTipoSolicitud3" key="3" text="{i18n>optTipoSolicitud3}"/>
                                <core:Item id="itemTipoSolicitud4" key="4" text="{i18n>optTipoSolicitud4}"/>
                            </items>
                        </Select>

                        <Label id="lblSolicitante" text="{i18n>lblSolicitante}" visible="{viewState>/fields/Solicitante}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Solicitante} }"/>
                        <Input id="inpSolicitante" value="{ui>/Solicitante}" editable="false" visible="{viewState>/fields/Solicitante}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Solicitante} &amp;&amp; !${ui>/Solicitante} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblNombreSolicitante" text="{i18n>lblNombreSolicitante}" visible="{viewState>/fields/NombreSolicitante}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreSolicitante} }"/>
                        <Input id="inpNombreSolicitante" value="{ui>/NombreSolicitante}" editable="{viewState>/Editable}" visible="{viewState>/fields/NombreSolicitante}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreSolicitante} &amp;&amp; !${ui>/NombreSolicitante} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblCiudad" text="{i18n>lblCiudad}" visible="{viewState>/fields/Ciudad}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Ciudad} }"/>
                        <Select id="selCiudad" selectedKey="{ui>/Ciudad}" enabled="{viewState>/Editable}" visible="{viewState>/fields/Ciudad}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Ciudad} &amp;&amp; !${ui>/Ciudad} ? 'Error' : 'None' }" items="{cities>/items}">
                            <items>
                                <core:Item id="itemCiudad" key="{cities>Nombre}" text="{cities>Nombre}"/>
                            </items>
                        </Select>

                        <Label id="lbslCentroCoto" text="{i18n>lblCentroCosto}" visible="{viewState>/fields/CentroCosto}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CentroCosto} }"/>
                        <Input id="inpCentroCosto" value="{ui>/CentroCosto}" editable="{viewState>/Editable}" visible="{viewState>/fields/CentroCosto}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CentroCosto} &amp;&amp; !${ui>/CentroCosto} ? 'Error' : 'None' }" valueLiveUpdate="true" showValueHelp="true" valueHelpRequest=".onCentroCosteVHRequest"/>

                        <Label id="lblLinea" text="{i18n>lblLinea}" visible="{viewState>/fields/Linea}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Linea} }"/>
                        <Input id="inpLinea" value="{ui>/Linea}" editable="{viewState>/Editable}" visible="{viewState>/fields/Linea}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Linea} &amp;&amp; !${ui>/Linea} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblCedulaRespActual" text="{i18n>lblCedulaRespActual}" visible="{viewState>/fields/CedulaRespActual}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRespActual} }"/>
                        <Input id="inpCedulaRespActual" value="{ui>/CedulaRespActual}" editable="{viewState>/Editable}" visible="{viewState>/fields/CedulaRespActual}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRespActual} &amp;&amp; !${ui>/CedulaRespActual} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblNombreRespActual" text="{i18n>lblNombreRespActual}" visible="{viewState>/fields/NombreRespActual}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreRespActual} }"/>
                        <Input id="inpNombreRespActual" value="{ui>/NombreRespActual}" editable="{viewState>/Editable}" visible="{viewState>/fields/NombreRespActual}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreRespActual} &amp;&amp; !${ui>/NombreRespActual} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblCedulaRespNuevo" text="{i18n>lblCedulaRespNuevo}" visible="{viewState>/fields/CedulaRespNuevo}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRespNuevo} }"/>
                        <Input id="inpCedulaRespNuevo" value="{ui>/CedulaRespNuevo}" editable="{viewState>/Editable}" visible="{viewState>/fields/CedulaRespNuevo}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRespNuevo} &amp;&amp; !${ui>/CedulaRespNuevo} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblNombreRespNuevo" text="{i18n>lblNombreRespNuevo}" visible="{viewState>/fields/NombreRespNuevo}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreRespNuevo} }"/>
                        <Input id="inpNombreRespNuevo" value="{ui>/NombreRespNuevo}" editable="{viewState>/Editable}" visible="{viewState>/fields/NombreRespNuevo}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/NombreRespNuevo} &amp;&amp; !${ui>/NombreRespNuevo} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblPersonaRecibeSim" text="{i18n>lblPersonaRecibeSim}" visible="{viewState>/fields/PersonaRecibeSim}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/PersonaRecibeSim} }"/>
                        <Input id="inpPersonaRecibeSim" value="{ui>/PersonaRecibeSim}" editable="{viewState>/Editable}" visible="{viewState>/fields/PersonaRecibeSim}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/PersonaRecibeSim} &amp;&amp; !${ui>/PersonaRecibeSim} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblCedulaRecibeSim" text="{i18n>lblCedulaRecibeSim}" visible="{viewState>/fields/CedulaRecibeSim}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRecibeSim} }"/>
                        <Input id="inpCedulaRecibeSim" value="{ui>/CedulaRecibeSim}" editable="{viewState>/Editable}" visible="{viewState>/fields/CedulaRecibeSim}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/CedulaRecibeSim} &amp;&amp; !${ui>/CedulaRecibeSim} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblAprobador" text="{i18n>lblAprobador}" visible="{viewState>/fields/Aprobador}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Aprobador} }"/>
                        <Select id="selAprobador" selectedKey="{ui>/Aprobador}" enabled="{viewState>/Editable}" visible="{viewState>/fields/Aprobador}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Aprobador} &amp;&amp; !${ui>/Aprobador} ? 'Error' : 'None' }" items="{managers>/items}">
                            <items>
                                <core:ListItem id="itemAprobador" key="{managers>Pernr}" text="{managers>Nombre}" additionalText="{managers>JobTitle}"/>
                            </items>
                        </Select>

                        <Label id="lblResponsableGestion" text="{i18n>lblResponsableGestion}" visible="{viewState>/fields/ResponsableGestion}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/ResponsableGestion} }"/>
                        <Input id="inpResponsableGestion" value="{ui>/ResponsableGestion}" editable="{viewState>/Editable}" visible="{viewState>/fields/ResponsableGestion}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/ResponsableGestion} &amp;&amp; !${ui>/ResponsableGestion} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblTipoEquipo" text="{i18n>lblTipoEquipo}" visible="{viewState>/fields/TipoEquipo}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/TipoEquipo} }"/>
                        <Input id="inpTipoEquipo" value="{ui>/TipoEquipo}" editable="{viewState>/Editable}" visible="{viewState>/fields/TipoEquipo}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/TipoEquipo} &amp;&amp; !${ui>/TipoEquipo} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblObservacion" text="{i18n>lblObservacion}" visible="{viewState>/fields/Observacion}" required="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Observacion} }"/>
                        <TextArea id="txtObservacion" value="{ui>/Observacion}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200" visible="{viewState>/fields/Observacion}" valueState="{= ${viewState>/Editable} &amp;&amp; ${viewState>/requiredFields/Observacion} &amp;&amp; !${ui>/Observacion} ? 'Error' : 'None' }" valueLiveUpdate="true"/>

                        <Label id="lblObsGestion" text="{i18n>lblObsGestion}" visible="{= ${viewState>/fields/ObsGestion} &amp;&amp; !${viewState>/Editable} }"/>
                        <TextArea id="txtObsGestion" value="{ui>/ObsGestion}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200" visible="{= ${viewState>/fields/ObsGestion} &amp;&amp; !${viewState>/Editable} }"/>

                        <Label id="lblObsAprobador" text="{i18n>lblObsAprobador}" visible="{= ${viewState>/fields/ObsAprobador} &amp;&amp; !${viewState>/Editable} }"/>
                        <TextArea id="txtObsAprobador" value="{ui>/ObsAprobador}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200" visible="{= ${viewState>/fields/ObsAprobador} &amp;&amp; !${viewState>/Editable} }"/>
                    </form:SimpleForm>

                    <VBox id="vboxCreateAttachments" visible="{viewState>/Editable}" class="sapUiSmallMarginTop">
                        <Label id="lblCreateAdjuntos" text="{i18n>titleAdjuntos}"/>
                        <unified:FileUploader id="fileUploaderAttachments" width="100%" change="onFileChange" uploadOnChange="false"/>
                        <List id="listAttachments" items="{ui>/Adjuntos}" mode="SingleSelect" growing="true">
                            <headerToolbar>
                                <OverflowToolbar id="toolbarCreateAttachments">
                                    <ToolbarSpacer id="toolbarSpacerCreateAttachments"/>
                                    <Button id="btnRemoveAttachment" icon="sap-icon://delete" type="Transparent" tooltip="Eliminar adjunto" press="onRemoveAttachment"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            <items>
                                <StandardListItem id="itemCreateAttachment" title="{ui>Nombre}" description="{ui>Tipo}"/>
                            </items>
                        </List>
                    </VBox>
                </Panel>

                <Panel id="panelAcciones" headerText="{i18n>titleAcciones}" visible="{viewState>/showActionPanel}" class="sapUiSmallMarginBottom">
                    <form:SimpleForm id="actionSimpleForm" layout="ResponsiveGridLayout">
                        <Label id="lblAcciones" text="{i18n>lblAcciones}"/>
                        <Select id="selectAction" visible="{viewState>/allowAction}">
                            <items>
                                <core:Item id="itemAccionAprobar" key="3" text="{i18n>optAccionAprobar}"/>
                                <core:Item id="itemAccionRechazar" key="4" text="{i18n>optAccionRechazar}"/>
                                <core:Item id="itemAccionFinalizar" key="5" text="{i18n>optAccionFinalizar}"/>
                            </items>
                        </Select>

                        <Label id="lblObservacionesAccion" text="{i18n>lblObservaciones}"/>
                        <TextArea id="txtAreaObservaciones" rows="3" growing="true" maxLength="200" editable="{viewState>/allowAction}"/>
                    </form:SimpleForm>
                </Panel>

                <Panel id="panelAdjuntos" headerText="{i18n>titleAdjuntos}" visible="{viewState>/showAdjuntos}">
                    <headerToolbar>
                        <Toolbar id="toolbarPanelAdjuntos">
                            <Title id="titlePanelAdjuntos" text="{i18n>titleAdjuntos}"/>
                            <ToolbarSpacer id="toolbarSpacerPanelAdjuntos"/>
                            <Button id="btnDownloadAttachments" icon="sap-icon://download" text="Descargar" press="onDownloadAttachments"/>
                        </Toolbar>
                    </headerToolbar>
                    <List id="listAttachmentsPanel" items="{ui>/Adjuntos}" mode="MultiSelect" growing="true">
                        <items>
                            <StandardListItem id="itemPanelAttachment" title="{ui>Nombre}" description="{ui>Tipo}"/>
                        </items>
                    </List>
                </Panel>

            </VBox>
        </content>
        <footer>
            <OverflowToolbar id="overFlowToolbarFooter">
                <ToolbarSpacer id="toolbarSpacerFooter"/>
                <Button id="btnSendRequest" text="{i18n>lblBtnSendRequest}" press="onSendRequest" icon="sap-icon://paper-plane" visible="{viewState>/showSendRequestButton}" enabled="{viewState>/canSendRequest}" type="Emphasized"/>
                <Button id="btnSendAction" text="{i18n>lblBtnSendAction}" type="Emphasized" press="onSendAction" visible="{viewState>/allowAction}"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
