<mvc:View controllerName="co.mitsubishi.flujotelefoniacelular.controller.Detail"
    xmlns:form="sap.ui.layout.form"
    xmlns:unified="sap.ui.unified"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Page id="detailPage" title="{i18n>detailViewTitle}{ui>/IdSolicitud}">
        <content>
            <VBox id="mainDetailPageVbox" class="sapUiSmallMarginBegin sapUiSmallMarginEnd">

                <Panel id="panelRequestForm" headerText="{i18n>titleRequestForm}" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
                    <form:SimpleForm id="requestSimpleForm" editable="{viewState>/Editable}" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="2" columnsM="2">
                        <Label id="lblCreadorSolicitud" text="{i18n>lblCreadorSolicitud}"/>
                        <Input id="inpCreadorSolicitud" value="{ui>/CreadorSolicitud}" editable="false"/>

                        <Label id="lblTipoSolicitud" text="{i18n>lblTipoSolicitud}"/>
                        <Select id="selTipoSolicitud" selectedKey="{ui>/TipoSolicitud}" editable="{viewState>/Editable}">
                            <items>
                                <core:Item id="itemTipoSolicitud1" key="1" text="{i18n>optTipoSolicitud1}"/>
                                <core:Item id="itemTipoSolicitud2" key="2" text="{i18n>optTipoSolicitud2}"/>
                                <core:Item id="itemTipoSolicitud3" key="3" text="{i18n>optTipoSolicitud3}"/>
                                <core:Item id="itemTipoSolicitud4" key="4" text="{i18n>optTipoSolicitud4}"/>
                            </items>
                        </Select>

                        <Label id="lblSolicitante" text="{i18n>lblSolicitante}"/>
                        <Input id="inpSolicitante" value="{ui>/Solicitante}" editable="false"/>

                        <Label id="lblNombreSolicitante" text="{i18n>lblNombreSolicitante}"/>
                        <Input id="inpNombreSolicitante" value="{ui>/NombreSolicitante}" editable="{viewState>/Editable}"/>

                        <Label id="lblCiudad" text="{i18n>lblCiudad}"/>
                        <Input id="inpCiudad" value="{ui>/Ciudad}" editable="{viewState>/Editable}"/>

                        <Label id="lblCentroCosto" text="{i18n>lblCentroCosto}"/>
                        <Input id="inpCentroCosto" value="{ui>/CentroCosto}" editable="{viewState>/Editable}"/>

                        <Label id="lblLinea" text="{i18n>lblLinea}"/>
                        <Input id="inpLinea" value="{ui>/Linea}" editable="{viewState>/Editable}"/>

                        <Label id="lblCedulaRespActual" text="{i18n>lblCedulaRespActual}"/>
                        <Input id="inpCedulaRespActual" value="{ui>/CedulaRespActual}" editable="{viewState>/Editable}"/>

                        <Label id="lblNombreRespActual" text="{i18n>lblNombreRespActual}"/>
                        <Input id="inpNombreRespActual" value="{ui>/NombreRespActual}" editable="{viewState>/Editable}"/>

                        <Label id="lblCedulaRespNuevo" text="{i18n>lblCedulaRespNuevo}"/>
                        <Input id="inpCedulaRespNuevo" value="{ui>/CedulaRespNuevo}" editable="{viewState>/Editable}"/>

                        <Label id="lblNombreRespNuevo" text="{i18n>lblNombreRespNuevo}"/>
                        <Input id="inpNombreRespNuevo" value="{ui>/NombreRespNuevo}" editable="{viewState>/Editable}"/>

                        <Label id="lblPersonaRecibeSim" text="{i18n>lblPersonaRecibeSim}"/>
                        <Input id="inpPersonaRecibeSim" value="{ui>/PersonaRecibeSim}" editable="{viewState>/Editable}"/>

                        <Label id="lblCedulaRecibeSim" text="{i18n>lblCedulaRecibeSim}"/>
                        <Input id="inpCedulaRecibeSim" value="{ui>/CedulaRecibeSim}" editable="{viewState>/Editable}"/>

                        <Label id="lblAprobador" text="{i18n>lblAprobador}"/>
                        <Input id="inpAprobador" value="{ui>/Aprobador}" editable="{viewState>/Editable}"/>

                        <Label id="lblResponsableGestion" text="{i18n>lblResponsableGestion}"/>
                        <Input id="inpResponsableGestion" value="{ui>/ResponsableGestion}" editable="{viewState>/Editable}"/>

                        <Label id="lblTipoEquipo" text="{i18n>lblTipoEquipo}"/>
                        <Input id="inpTipoEquipo" value="{ui>/TipoEquipo}" editable="{viewState>/Editable}"/>

                        <Label id="lblObservacion" text="{i18n>lblObservacion}"/>
                        <TextArea id="txtObservacion" value="{ui>/Observacion}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200"/>

                        <Label id="lblObsGestion" text="{i18n>lblObsGestion}"/>
                        <TextArea id="txtObsGestion" value="{ui>/ObsGestion}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200" visible="{= !${viewState>/Editable} }"/>

                        <Label id="lblObsAprobador" text="{i18n>lblObsAprobador}"/>
                        <TextArea id="txtObsAprobador" value="{ui>/ObsAprobador}" editable="{viewState>/Editable}" rows="3" growing="true" maxLength="200" visible="{= !${viewState>/Editable} }"/>
                    </form:SimpleForm>

                    <VBox id="vboxCreateAttachments" visible="{viewState>/Editable}" class="sapUiSmallMarginTop">
                        <Label id="lblCreateAdjuntos" text="{i18n>titleAdjuntos}"/>
                        <unified:FileUploader id="fileUploaderAttachments" width="100%" change="onFileChange" uploadOnChange="false"/>
                        <List id="listAttachments" items="{ui>/Adjuntos}" mode="SingleSelect" growing="true">
                            <headerToolbar>
                                <OverflowToolbar id="toolbarCreateAttachments">
                                    <ToolbarSpacer id="toolbarSpacerCreateAttachments"/>
                                    <Button id="btnRemoveAttachment" icon="sap-icon://delete" type="Transparent" tooltip="Eliminar adjunto" press="onRemoveAttachment"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            <items>
                                <StandardListItem id="itemCreateAttachment" title="{ui>Nombre}" description="{ui>Tipo}"/>
                            </items>
                        </List>
                    </VBox>
                </Panel>

                <Panel id="panelAcciones" headerText="{i18n>titleAcciones}" visible="{viewState>/showActionPanel}" class="sapUiSmallMarginBottom">
                    <form:SimpleForm id="actionSimpleForm" layout="ResponsiveGridLayout">
                        <Label id="lblAcciones" text="{i18n>lblAcciones}"/>
                        <Select id="selectAction" visible="{viewState>/allowAction}">
                            <items>
                                <core:Item id="itemAccionAprobar" key="3" text="{i18n>optAccionAprobar}"/>
                                <core:Item id="itemAccionRechazar" key="4" text="{i18n>optAccionRechazar}"/>
                                <core:Item id="itemAccionFinalizar" key="5" text="{i18n>optAccionFinalizar}"/>
                            </items>
                        </Select>

                        <Label id="lblObservacionesAccion" text="{i18n>lblObservaciones}"/>
                        <TextArea id="txtAreaObservaciones" rows="3" growing="true" maxLength="200" editable="{viewState>/allowAction}"/>
                    </form:SimpleForm>
                </Panel>

                <Panel id="panelAdjuntos" headerText="{i18n>titleAdjuntos}" visible="{viewState>/showAdjuntos}">
                    <headerToolbar>
                        <Toolbar id="toolbarPanelAdjuntos">
                            <Title id="titlePanelAdjuntos" text="{i18n>titleAdjuntos}"/>
                            <ToolbarSpacer id="toolbarSpacerPanelAdjuntos"/>
                            <Button id="btnDownloadAttachments" icon="sap-icon://download" text="Descargar" press="onDownloadAttachments"/>
                        </Toolbar>
                    </headerToolbar>
                    <List id="listAttachmentsPanel" items="{ui>/Adjuntos}" mode="MultiSelect" growing="true">
                        <items>
                            <StandardListItem id="itemPanelAttachment" title="{ui>Nombre}" description="{ui>Tipo}"/>
                        </items>
                    </List>
                </Panel>

            </VBox>
        </content>
        <footer>
            <OverflowToolbar id="overFlowToolbarFooter">
                <ToolbarSpacer id="toolbarSpacerFooter"/>
                <Button id="btnSendRequest" text="{i18n>lblBtnSendRequest}" press="onSendRequest" icon="sap-icon://paper-plane" visible="{viewState>/showSendRequestButton}" type="Emphasized"/>
                <Button id="btnSendAction" text="{i18n>lblBtnSendAction}" type="Emphasized" press="onSendAction" visible="{viewState>/allowAction}"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
