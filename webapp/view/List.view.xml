<mvc:View controllerName="co.mitsubishi.flujotelefoniacelular.controller.List"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="listPage" title="{i18n>listViewTitle}">
        <List id="mainList" items="{requests>/items}" itemPress=".onListItemPress">
            <CustomListItem id="customListItem" type="Active">
                <VBox id="vboxCustomListItem" class="sapUiSmallMargin">
                    <Text id="titleListItem" text="Solicitud N° {requests>Id_Solicitud}" class="sapMTitle sapUiTinyMarginBottom"/>
                    <Text id="txtCentroCoste" text="{i18n>lblCentroCostoList}: {requests>CentroCosto}" wrapping="true"/>
                    <Text id="txtSolicitante" text="{i18n>lblSolicitanteList}: {requests>Solicitante}" wrapping="true"/>
                    <ObjectStatus id="objectStatus" text="{path: 'requests>Estado', formatter: '.Adapter.formatStatusText'}" state="{path: 'requests>Estado', formatter: '.Adapter.formatStatusState'}" inverted="true" class="sapUiSmallMarginTop"/>
                </VBox>
            </CustomListItem>
        </List>
        <footer>
            <OverflowToolbar id="overFlowToolBarListPage">
                <ToolbarSpacer id="toolbarSpacer"/>
                <Button id="btnCreate" text="{i18n>btnCreate}" icon="sap-icon://add" press="onCreate"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
